<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Dalamud.NET.Sdk/14.0.2">
    <PropertyGroup>
        <Version>0.0.0.1</Version>
        <PackageProjectUrl>https://github.com/goatcorp/SamplePlugin</PackageProjectUrl>
        <PackageLicenseExpression>AGPL-3.0-or-later</PackageLicenseExpression>
        <IsPackable>false</IsPackable>
        <AssemblyName>MothJack</AssemblyName>
        <Name>MothJack</Name>
        <Author>Vorpal Gabbiani</Author>
        <Punchline>Blackjack dealer dashboard for FFXIV</Punchline>
        <Description>A dealer-side dashboard for running Blackjack games in FFXIV. Tracks hand totals, splits, doubles, busts, and player banks automatically via party chat macros.</Description>
        <RepoUrl></RepoUrl>
        <Tags>blackjack,casino,dealer,game</Tags>
        <DalamudApiLevel>12</DalamudApiLevel>
    </PropertyGroup>

    <ItemGroup>
        <Content Include="..\Data\goat.png">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
            <Visible>false</Visible>
        </Content>
    </ItemGroup>
</Project>